# ===========================================
# Elixa - AI-Powered Event Management
# Environment Variables
# ===========================================

# ------ AI Services ------

# Groq API Key (for Mid-Event Agent command parsing)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Groq model override for the mid-event agent
# Default in code: llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini API Key (for Rule Compilation, Event Setup, Mid-Event Agent, Post-Event Summary)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# ------ Voice Services ------

# ElevenLabs API Key (for Voice Output / TTS)
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Custom ElevenLabs Voice ID
# ELEVENLABS_VOICE_ID=your_preferred_voice_id

# ------ Database ------

# MongoDB Atlas Connection URI
# Get yours at: https://cloud.mongodb.com/
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/elixa?retryWrites=true&w=majority

# ------ Real-time State (SpacetimeDB) ------

# SpacetimeDB Module URI
# Deploy your module and get the URI from: https://spacetimedb.com/
SPACETIMEDB_URI=wss://your-module.spacetimedb.com

# SpacetimeDB Module Name
SPACETIMEDB_MODULE_NAME=elixa

# Optional HTTP relay for app server calls to SpaceTimeDB reducers/queries
# Expected endpoints:
#   POST {SPACETIMEDB_RELAY_URL}/game-sessions/create
#   POST {SPACETIMEDB_RELAY_URL}/game-sessions/list
#   POST {SPACETIMEDB_RELAY_URL}/game-sessions/load
#   POST {SPACETIMEDB_RELAY_URL}/game-sessions/save-progress
#   POST {SPACETIMEDB_RELAY_URL}/game-sessions/append-event
SPACETIMEDB_RELAY_URL=http://localhost:4000

# ------ Optional Configuration ------

# Application URL (for CORS, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Web App Config (required for Google sign-in on landing page)
# Create a Firebase project and enable Google auth provider:
# https://console.firebase.google.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Enable debug logging
# DEBUG=true
